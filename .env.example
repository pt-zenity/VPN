# Copia este fichero a .env y ajusta los valores. NUNCA subas tu .env a GitHub.

# Trabaja contra el sandbox (true) o contra el servidor real (false).
VPNM_SANDBOX=true

# ── Autenticación del panel ───────────────────────────────────────────────
# Usuario administrador.
VPNM_ADMIN_USER=admin
# Hash de la contraseña. Genéralo con:  python -m vpn_manager.hashpw
# En producción es OBLIGATORIO (sin él, el panel no arranca).
VPNM_ADMIN_PASSWORD_HASH=
# Clave para firmar la cookie de sesión (cadena larga y aleatoria).
# Genérala con:  python -c "import secrets; print(secrets.token_hex(32))"
VPNM_SECRET_KEY=
# Pon true cuando sirvas el panel detrás de HTTPS.
VPNM_COOKIE_SECURE=false

# ── Rutas reales (solo si VPNM_SANDBOX=false) ─────────────────────────────
# VPNM_OPENVPN_PKI_INDEX=/etc/openvpn/server/pki/index.txt
# VPNM_OPENVPN_STATUS_FILE=/var/log/openvpn/status.log
# VPNM_OPENVPN_SERVICE=openvpn-server@server

# ── Instalación de servicios (la app instala OpenVPN/WireGuard) ───────────
# Interruptor de seguridad: en producción debe ser true para permitir instalar
# (además hay que ejecutar el panel como root).
VPNM_ALLOW_INSTALL=false
# Instalación «llave en mano» con los scripts de angristan (MIT). PINEA un commit
# concreto en la URL y verifica su checksum (sin SHA-256 NO se ejecuta).
# Cómputo del hash:  curl -sL <url> | sha256sum
# VPNM_BOOTSTRAP_OPENVPN_URL=https://raw.githubusercontent.com/angristan/openvpn-install/<COMMIT>/openvpn-install.sh
# VPNM_BOOTSTRAP_OPENVPN_SHA256=
# VPNM_BOOTSTRAP_WIREGUARD_URL=https://raw.githubusercontent.com/angristan/wireguard-install/<COMMIT>/wireguard-install.sh
# VPNM_BOOTSTRAP_WIREGUARD_SHA256=
